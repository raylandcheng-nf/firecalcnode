# Required
SECRET_KEY=replace-with-a-long-random-secret
APP_ENV=production

# Network
HOST=0.0.0.0
PORT=8080

# Request body limit (bytes)
MAX_CONTENT_LENGTH=16384

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_REQUIRE_REDIS=true
RATE_LIMIT_MEMORY_MAX_KEYS=50000
REDIS_URL=redis://127.0.0.1:6379/0

# Session storage
SESSION_STORE_BACKEND=redis
SESSION_REQUIRE_REDIS=true
SESSION_REDIS_URL=redis://127.0.0.1:6379/0
SESSION_REDIS_PREFIX=sess:

# Reverse proxy / IP handling
TRUST_PROXY=false

# Session cookie
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_MAX_AGE_SECONDS=43200
